# APP
GLITCHTIP_RETENTION_DAYS=180
GLITCHTIP_TRANSACTION_RETENTION_DAYS=180
GLITCHTIP_UPTIME_RETENTION_DAYS=180
GLITCHTIP_FILE_RETENTION_DAYS=180
SECRET_KEY={{ sentry_secret_key }}
GLITCHTIP_DOMAIN=https://sentry.wigger.one
GLITCHTIP_INSTANCE_NAME=Sentry
PORT=8000
LOG_LEVEL=INFO

# DB
DATABASE_URL=postgres://sentry:{{ postgres_pw }}@db.local:5432/sentry
VALKEY_URL=redis://:{{ redis_pw }}@db.local:6379/2
#MAINTENANCE_EVENT_FREEZE

# S3
DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage
AWS_ACCESS_KEY_ID={{ s3_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ s3_secret_access_key }}
AWS_STORAGE_BUCKET_NAME=sentry
AWS_S3_ENDPOINT_URL={{ s3_url }}

# SMTP
EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
MAILGUN_API_URL=https://api.eu.mailgun.net/v3
MAILGUN_API_KEY={{ mailgun_api_key }}
MAILGUN_SENDER_DOMAIN=www.wigger.one
DEFAULT_FROM_EMAIL={{ smtp_user }}

# WORKER
CELERY_WORKER_AUTOSCALE=2,8
CELERY_WORKER_CONCURRENCY=2
GRANIAN_WORKERS=1

# Etc
ENABLE_USER_REGISTRATION=false
ENABLE_SOCIAL_APPS_USER_REGISTRATION=true
GLITCHTIP_ENABLE_UPTIME=true
GLITCHTIP_ENABLE_LOGS=true
ENABLE_ORGANIZATION_CREATION=true
ENABLE_OBSERVABILITY_API=true
I_PAID_FOR_GLITCHTIP=true
